{
  "name": "Job Cluster",
  "description": "Policy for automated job clusters with cost optimization",
  "definition": {
    "spark_version": {
      "type": "regex",
      "pattern": "1[3-5]\\.[0-9]+\\.x-scala.*",
      "defaultValue": "14.3.x-scala2.12"
    },
    "cluster_type": {
      "type": "fixed",
      "value": "job"
    },
    "custom_tags.CostCenter": {
      "type": "regex",
      "pattern": ".*"
    },
    "custom_tags.JobName": {
      "type": "regex",
      "pattern": ".*"
    },
    "num_workers": {
      "type": "range",
      "minValue": 1,
      "maxValue": 50
    },
    "autoscale.min_workers": {
      "type": "range",
      "minValue": 1,
      "maxValue": 10,
      "defaultValue": 1
    },
    "autoscale.max_workers": {
      "type": "range",
      "minValue": 2,
      "maxValue": 50,
      "defaultValue": 10
    },
    "node_type_id": {
      "type": "allowlist",
      "values": [
        "Standard_D4ds_v5",
        "Standard_D8ds_v5",
        "Standard_D16ds_v5",
        "Standard_D32ds_v5",
        "Standard_E4ds_v5",
        "Standard_E8ds_v5",
        "Standard_E16ds_v5"
      ],
      "defaultValue": "Standard_D8ds_v5"
    },
    "driver_node_type_id": {
      "type": "allowlist",
      "values": [
        "Standard_D4ds_v5",
        "Standard_D8ds_v5",
        "Standard_D16ds_v5"
      ],
      "defaultValue": "Standard_D8ds_v5"
    },
    "azure_attributes.spot_bid_max_price": {
      "type": "range",
      "minValue": -1,
      "maxValue": 10,
      "defaultValue": -1
    },
    "azure_attributes.first_on_demand": {
      "type": "range",
      "minValue": 0,
      "maxValue": 3,
      "defaultValue": 1
    }
  }
}
